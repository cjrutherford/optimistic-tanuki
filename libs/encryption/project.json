{
  "name": "encryption",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/encryption/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:util", "visibility:publishable"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/encryption",
        "main": "libs/encryption/src/index.ts",
        "tsConfig": "libs/encryption/tsconfig.lib.json",
        "assets": ["libs/encryption/package.json", "libs/encryption/README.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/encryption/jest.config.ts"
      }
    }
  }
}
