{
  "name": "billing-sdk",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/billing-sdk/src",
  "projectType": "library",
  "tags": [
    "type:feature",
    "scope:billing",
    "platform:shared",
    "visibility:publishable"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/billing-sdk",
        "main": "libs/billing-sdk/src/index.ts",
        "tsConfig": "libs/billing-sdk/tsconfig.lib.json",
        "assets": ["libs/billing-sdk/package.json", "libs/billing-sdk/README.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/billing-sdk/jest.config.ts"
      }
    }
  }
}
