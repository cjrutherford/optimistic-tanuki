{
  "name": "app-config-models",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/app-config-models/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/app-config-models",
        "main": "libs/app-config-models/src/index.ts",
        "tsConfig": "libs/app-config-models/tsconfig.lib.json",
        "assets": ["libs/app-config-models/*.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/app-config-models/jest.config.ts"
      }
    }
  }
}
