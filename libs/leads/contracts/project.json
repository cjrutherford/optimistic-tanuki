{
  "name": "leads-contracts",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/leads/contracts/src",
  "projectType": "library",
  "tags": [
    "type:contracts",
    "scope:leads",
    "platform:shared",
    "visibility:publishable"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/leads/contracts",
        "main": "libs/leads/contracts/src/index.ts",
        "tsConfig": "libs/leads/contracts/tsconfig.lib.json",
        "assets": [
          "libs/leads/contracts/package.json",
          "libs/leads/contracts/README.md"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/leads/contracts/jest.config.ts"
      }
    }
  }
}
