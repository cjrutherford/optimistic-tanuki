{
  "name": "constants",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/constants/src",
  "projectType": "library",
  "tags": [
    "type:util",
    "scope:shared",
    "platform:shared",
    "visibility:publishable"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/constants",
        "main": "libs/constants/src/index.ts",
        "tsConfig": "libs/constants/tsconfig.lib.json",
        "assets": ["libs/constants/package.json", "libs/constants/README.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/constants/jest.config.ts"
      }
    }
  }
}
