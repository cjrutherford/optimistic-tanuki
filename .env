# Optimistic Tanuki Environment Configuration
# Non-sensitive configuration values
# This file can be committed to version control

# Application Environment
NODE_ENV=development
LOG_LEVEL=debug

# Service Ports
GATEWAY_PORT=3000
AUTHENTICATION_PORT=3001
PROFILE_PORT=3002
SOCIAL_PORT=3003
ASSETS_PORT=3005
PROJECT_PLANNING_PORT=3006
CHAT_COLLECTOR_PORT=3007
TELOS_DOCS_PORT=3008
PROMPT_PROXY_PORT=3009
AI_ORCHESTRATION_PORT=3010
BLOGGING_PORT=3011
PERMISSIONS_PORT=3012
STORE_PORT=3013
APP_CONFIGURATOR_PORT=3014
FORUM_PORT=3015
WELLNESS_PORT=3016

# Client Ports
CLIENT_INTERFACE_PORT=8080
FORGE_OF_WILL_PORT=8081
DIGITAL_HOMESTEAD_PORT=8082
CHRISTOPHERRUTHERFORD_NET_PORT=8083
OWNER_CONSOLE_PORT=8084
STORE_CLIENT_PORT=8085
D6_PORT=8086
CONFIGURABLE_CLIENT_PORT=8090

# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Storage
STORAGE_STRATEGY=local
S3_REGION=us-east-1

# Ollama
OLLAMA_API_PORT=11434

# Domain
DOMAIN=localhost
PROTOCOL=http

# Feature Flags
ENABLE_METRICS=true
ENABLE_TRACING=false
