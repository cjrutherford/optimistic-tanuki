# Optimistic Tanuki deployment environment sample
# Intended for `docker compose --env-file <file> -f docker-compose.yaml ...`
# Keep secrets out of git. Copy this to `.env.production` or another deploy-specific file.

# Required deployment identity
NODE_ENV=production
LOG_LEVEL=info
DOMAIN=example.com
PROTOCOL=https
ENABLE_METRICS=true
ENABLE_TRACING=false
GATEWAY_URL=http://gateway:3000
GATEWAY_WS_URL=http://gateway:3300
# Public Socket.IO endpoint for browser clients. Production routes this path through Nginx.
SOCKET_URL=
SOCKET_PATH=/socket.io

# Required image/version selection
PRODUCTION_IMAGE_TAG=sha-REPLACE_WITH_IMAGE_TAG
GIT_SHA=REPLACE_WITH_GIT_SHA

# Required application secrets
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_POSTGRES_PASSWORD
POSTGRES_DB=postgres
REDIS_PASSWORD=
JWT_SECRET=REPLACE_WITH_STRONG_JWT_SECRET

# Required service hosts and infra endpoints
POSTGRES_HOST=db
POSTGRES_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
ASSETS_HOST=assets
VIDEO_TRANSCODER_HOST=video-transcoder-worker
VIDEO_TRANSCODER_PORT=3023

# Required runtime registry mount for gateway
# The host file should point at the deploy-specific registry JSON for app URLs and OAuth return routing.
APP_REGISTRY_HOST_PATH=/opt/optimistic-tanuki/config/app-registry.production.json
APP_REGISTRY_PATH=/usr/src/app/config/app-registry.json

# Shared OAuth providers
# Precedence: built-in provider metadata < service config.yaml < non-empty environment values.
# Redirect URIs are optional when the registry contains client-interface.uiBaseUrl;
# the shown values document the production provider callback registrations.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://optimistic-tanuki.com/oauth/callback/google
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://optimistic-tanuki.com/oauth/callback/github
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://optimistic-tanuki.com/oauth/callback/microsoft
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=https://optimistic-tanuki.com/oauth/callback/facebook

# Payments and commerce
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_BASIC_VARIANT_ID=
LEMON_SQUEEZY_PRO_VARIANT_ID=
LEMON_SQUEEZY_ENTERPRISE_VARIANT_ID=

# Optional integrations
SMTP_HOST=mail.christopherrutherford.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@christopherrutherford.net
SMTP_PASS=
SMTP_FROM=no-reply@christopherrutherford.net

STORAGE_STRATEGY=local
S3_REGION=us-east-1
GOOGLE_MAPS_API_KEY=
LEAD_DISCOVERY_SEARCH_GOOGLE_API_KEY=
LEAD_DISCOVERY_SEARCH_GOOGLE_CX=
LEAD_DISCOVERY_GOOGLE_MAPS_API_KEY=
OLLAMA_HOST=prompt-proxy
OLLAMA_PORT=11434
OLLAMA_MODEL=gemma3
OLLAMA_API_PORT=11434

# Published service ports
GATEWAY_PORT=3000
GATEWAY_CHAT_SOCKET_PORT=3300
GATEWAY_SOCIAL_SOCKET_PORT=3301
AUTHENTICATION_PORT=3001
PROFILE_PORT=3002
SOCIAL_PORT=3003
ASSETS_PORT=3005
PROJECT_PLANNING_PORT=3006
CHAT_COLLECTOR_PORT=3007
TELOS_DOCS_PORT=3008
PROMPT_PROXY_PORT=3009
AI_ORCHESTRATION_PORT=3010
BLOGGING_PORT=3011
PERMISSIONS_PORT=3012
STORE_PORT=3013
APP_CONFIGURATOR_PORT=3014
FORUM_PORT=3015
FINANCE_PORT=3016
CLASSIFIEDS_PORT=3017
WELLNESS_PORT=3018
LEAD_TRACKER_PORT=3020
SYSTEM_CONFIGURATOR_API_PORT=3021
VIDEOS_PORT=3022
PAYMENTS_PORT=3004
VIDEO_TRANSCODER_PORT=3023

# Published frontend ports
CLIENT_INTERFACE_PORT=8080
FORGE_OF_WILL_PORT=8081
DIGITAL_HOMESTEAD_PORT=8082
CHRISTOPHERRUTHERFORD_NET_PORT=8083
OWNER_CONSOLE_PORT=8084
STORE_CLIENT_PORT=8085
D6_PORT=8086
LOCAL_HUB_PORT=8087
HAI_PORT=8088
FIN_COMMANDER_PORT=8089
CONFIGURABLE_CLIENT_PORT=8090
SYSTEM_CONFIGURATOR_PORT=8091
MARKETING_GENERATOR_PORT=8092
VIDEO_CLIENT_PORT=8093
BUSINESS_SITE_PORT=8094
LEADS_APP_PORT=8095
BUSINESS_CONFIGURATOR_PORT=8096
DEVELOPER_PORTAL_PORT=8097

# Optional filesystem and media mounts
ASSETS_HOST_PATH=
VIDEO_SEED_SOURCE_DIR=
VIDEO_SEED_SOURCE_HOST_PATH=

# Optional local/dev-only seed knobs
APP_SCOPE=local-hub
GATEWAY_API_URL=http://gateway:3000/api
GATEWAY_BASE_URL=http://gateway:3000
HOST_GATEWAY_BASE_URL=http://127.0.0.1:3000
HOST_GATEWAY_READY_URL=http://127.0.0.1:3000/api-docs
DOCKER_BATCH_SIZE=10
