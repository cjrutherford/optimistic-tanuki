# Optimistic Tanuki Secrets
# Copy this file to .secrets and fill in your values
# DO NOT commit .secrets to version control

# Database Configuration
POSTGRES_PASSWORD=changeme
POSTGRES_USER=postgres
POSTGRES_DB=postgres

# JWT and OAuth state secrets (use distinct high-entropy values)
JWT_SECRET=c3VwZXJzZWNyZXRzdHJpbmc=
# Required by the gateway; do not reuse JWT_SECRET.
OAUTH_STATE_SECRET=

# Lemon Squeezy webhook signing secret (from the store's webhook settings).
# Leave blank to disable webhook processing (webhooks fail closed / 401).
LEMON_SQUEEZY_WEBHOOK_SECRET=

# Shared gateway OAuth providers
# Provider IDs/secrets stay gateway-scoped in Kubernetes. Redirect values may
# be left blank to use client-interface.uiBaseUrl from the application registry.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://optimistic-tanuki.com/oauth/callback/google
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://optimistic-tanuki.com/oauth/callback/github
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://optimistic-tanuki.com/oauth/callback/microsoft
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=https://optimistic-tanuki.com/oauth/callback/facebook
# Transactional email. SMTP_HOST enables real delivery; leave it empty only for
# local console-email development. Use SMTP_SECURE=true for implicit TLS (465)
# or false for STARTTLS (usually 587).
SMTP_HOST=mail.christopherrutherford.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@christopherrutherford.net
SMTP_PASS=
SMTP_FROM=no-reply@christopherrutherford.net

# SeaweedFS/S3 Configuration
S3_ENDPOINT=http://seaweedfs:8888
S3_BUCKET=assets
S3_ACCESS_KEY=seaweedfs
S3_SECRET_KEY=seaweedfs

# Ollama API (for AI services)
OLLAMA_API_URL=http://ollama
OLLAMA_API_PORT=11434

# Redis
REDIS_PASSWORD=

# External Database URL (for production)
DATABASE_URL=postgresql://postgres:changeme@db:5432/ot_main

# Domain Configuration
DOMAIN=localhost
PROTOCOL=http

# Docker Hub Credentials
DOCKER_USERNAME=
DOCKER_PASSWORD=
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=

# ArgoCD
ARGOCD_USERNAME=admin
ARGOCD_PASSWORD=
ARGOCD_SERVER=

# Kubernetes
KUBECONFIG=

# GitHub
GITHUB_TOKEN=

# Tailscale OAuth (for Kubernetes operator)
# Get these from https://login.tailscale.com/admin/settings/oauth
TAILSCALE_OAUTH_CLIENT_ID=
TAILSCALE_OAUTH_CLIENT_SECRET=
TAILSCALE_FQDN=
