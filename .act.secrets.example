# .act.secrets — local secrets for running GitHub Actions with 'act'
#
# Copy this file to .act.secrets and fill in values for your environment.
# The file .act.secrets is git-ignored so secrets are never committed.
#
# IMPORTANT: Replace ALL 'your-*' placeholder values below with your actual credentials.
#
# Usage:
#   ./scripts/run-workflow-act.sh lint.yml
#   # run-workflow-act.sh auto-loads this file when present
#
# See docs/devops/github-actions-validation.md for full act usage guide.
# -----------------------------------------------------------------

# Docker Hub credentials (used by docker-publish, build-push, deploy workflows)
DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_TOKEN=your-dockerhub-access-token

# GitHub token (available in most workflows; usually not needed for lint/build/test)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=your-github-personal-access-token

# Codecov token (used by coverage.yml)
CODECOV_TOKEN=your-codecov-token

# Deployment secrets (used by deploy.yml — Tier 3, not run locally by default)
# KUBECONFIG=base64-encoded-kubeconfig
# DOMAIN=your-domain.com
# ARGOCD_PASSWORD=your-argocd-admin-password
# STAGING_URL=https://staging.your-domain.com
# PRODUCTION_URL=https://your-domain.com
