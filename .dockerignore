# Global Docker ignore rules for the Optimistic Tanuki workspace
# These apply to all builds that use the workspace root as the build context.
#
# Goals:
# - Keep Docker build contexts small and fast
# - Exclude local-only artifacts (coverage, screenshots, logs, etc.)
# - Preserve source and dist outputs needed by Nx/Docker builds

# Node / package managers
node_modules
**/node_modules
.pnpm-store
npm-debug.log*

# Git / IDE / tooling
.git
.gitignore
.github
.vscode
.idea

# Nx / tooling caches and temp
.nx
.tmp
tmp
.temp

# Angular CLI / Vite caches (these confuse Nx project graph inside Docker)
.angular
**/.angular

# Test / coverage / e2e artifacts
coverage
**/coverage

test-results
**/test-results

# E2E and Playwright outputs
apps/*-e2e
apps/**/test-results
apps/**/playwright-report
**/playwright-report
**/playwright-report/**

# Large local-only resources
screenshots
**/screenshots
storage
codepen-material
storybook-static
documentation.json
.opencode
.kilo
.playwright-mcp
setup-console-step1-after.png
setup-console-step1-fixed.png
setup-console-step1-final.png

# Logs
**/*.log

# Build outputs are no longer used as Docker build inputs.
dist
