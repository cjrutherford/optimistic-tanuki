{
  "name": "fin-commander-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/fin-commander-e2e/src",
  "implicitDependencies": ["fin-commander"],
  "targets": {
    "e2e": {
      "executor": "@nx/playwright:playwright",
      "options": {
        "config": "apps/fin-commander-e2e/playwright.config.ts"
      },
      "configurations": {
        "ci": {
          "env": {
            "CI": "true",
            "BASE_URL": "http://localhost:8089",
            "GATEWAY_URL": "http://localhost:3000"
          }
        },
        "docker": {
          "env": {
            "E2E_DOCKER": "true",
            "CI": "true",
            "BASE_URL": "http://localhost:8089",
            "GATEWAY_URL": "http://localhost:3000"
          }
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/fin-commander-e2e/jest.config.ts"
      }
    }
  }
}
