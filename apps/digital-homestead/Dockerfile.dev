# Stage 1: Build the Angular SSR application
FROM node:lts-alpine as builder

# Set working directory
WORKDIR /usr/src/app

# Copy package.json and package-lock.json
COPY package.json ./
COPY package-lock.json ./

# Install all dependencies (including devDependencies needed for build)
RUN npm install --legacy-peer-deps

# Copy the entire workspace source code
# Nx needs this to build the application and its dependencies
COPY . .

# Build the client-interface application for development with SSR
# This will output to dist/apps/digital-homestead and include server/main.js
RUN npx nx build digital-homestead --configuration=development

# Stage 2: Create the runtime image from a slim Node.js base
FROM node:lts-alpine
RUN apk add --no-cache dumb-init

WORKDIR /app

# Set NODE_ENV to development for the runtime environment to enable detailed errors/logs
ENV NODE_ENV=development

# Copy package.json and package-lock.json again to install dependencies
COPY --from=builder /usr/src/app/package.json ./
COPY --from=builder /usr/src/app/package-lock.json ./

# Install all dependencies (dev included) for potential debugging/hot-reloading support inside container
RUN npm install --legacy-peer-deps && npm i -g nodemon

# Copy the built application (server and browser bundles) from the builder stage
COPY --from=builder /usr/src/app/dist/apps/digital-homestead ./dist/apps/digital-homestead

# Expose the port the SSR server will listen on.
EXPOSE 4000

# Command to run the SSR server.
CMD ["node", "/app/dist/apps/digital-homestead/server/server.mjs"]
