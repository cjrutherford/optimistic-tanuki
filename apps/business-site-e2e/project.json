{
  "name": "business-site-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/business-site-e2e/src",
  "implicitDependencies": [
    "business-site"
  ],
  "targets": {
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "apps/business-site-e2e/jest.config.ts"
      }
    },
    "e2e": {
      "executor": "@nx/playwright:playwright",
      "options": {
        "config": "apps/business-site-e2e/playwright.config.ts"
      }
    }
  },
  "tags": [
    "type:e2e"
  ]
}
