{
  "name": "client-interface-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/client-interface-e2e/src",
  "implicitDependencies": ["client-interface"],
  "// targets": "to see all targets run: nx show project client-interface-e2e --web",
  "targets": {
    "up": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f e2e/docker-compose.client-interface-e2e.yaml up -d --build"
      }
    },
    "down": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f e2e/docker-compose.client-interface-e2e.yaml down -v"
      }
    },
    "e2e": {
      "executor": "@nx/playwright:playwright",
      "options": {
        "config": "apps/client-interface-e2e/playwright.config.ts"
      },
      "configurations": {
        "ci": {
          "env": {
            "BASE_URL": "http://localhost:8080"
          }
        }
      }
    },
    "chat-debug": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec playwright test --config=apps/client-interface-e2e/playwright.config.ts --project=chromium-desktop --grep=@chat-debug"
      }
    },
    "e2e-docker": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run client-interface-e2e:up",
          "echo 'Stack started. Waiting for services...'",
          "sleep 45",
          "docker compose -f e2e/docker-compose.client-interface-e2e.yaml run --rm playwright-runner pnpm exec nx run client-interface-e2e:e2e --skip-nx-cache",
          "nx run client-interface-e2e:down"
        ],
        "parallel": false
      }
    }
  },
  "tags": ["type:e2e"]
}
