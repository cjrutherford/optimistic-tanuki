{
  "name": "client-interface",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/client-interface/src",
  "tags": ["type:app"],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/client-interface",
        "index": "apps/client-interface/src/index.html",
        "browser": "apps/client-interface/src/main.ts",
        "allowedCommonJsDependencies": [
          "quill-delta",
          "quill-magic-url",
          "quill-mention",
          "quill-image-compress",
          "quill-cursors",
          "quill-placeholder-module",
          "http-proxy-middleware",
          "debug",
          "xmlhttprequest-ssl",
          "socket.io-client",
          "socket.io-parser",
          "engine.io-client"
        ],
        "polyfills": ["zone.js"],
        "tsConfig": "apps/client-interface/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/client-interface/public"
          }
        ],
        "styles": ["apps/client-interface/src/styles.scss"],
        "scripts": [],
        "server": "apps/client-interface/src/main.server.ts",
        "ssr": {
          "entry": "apps/client-interface/src/server.ts"
        },
        "prerender": true
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "1mb",
              "maximumError": "2mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "8kb",
              "maximumError": "40kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        },
        "mobile": {
          "outputMode": "static",
          "server": false,
          "ssr": false,
          "prerender": false,
          "outputHashing": "all",
          "sourceMap": false,
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "1mb",
              "maximumError": "2mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "8kb",
              "maximumError": "40kb"
            }
          ],
          "fileReplacements": [
            {
              "replace": "apps/client-interface/src/environments/app-env.ts",
              "with": "apps/client-interface/src/environments/app-env.mobile.ts"
            }
          ]
        },
        "mobile-dev": {
          "outputMode": "static",
          "server": false,
          "ssr": false,
          "prerender": false,
          "outputHashing": "all",
          "sourceMap": false,
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "1mb",
              "maximumError": "2mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "8kb",
              "maximumError": "40kb"
            }
          ]
        }
      },
      "defaultConfiguration": "production"
    },
    "mobile-sync": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "pnpm exec nx build client-interface --configuration mobile",
          "pnpm exec cap sync"
        ],
        "cwd": "apps/client-interface",
        "parallel": false
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@angular-devkit/build-angular:dev-server",
      "options": {
        "proxyConfig": "apps/client-interface/proxy.conf.json"
      },
      "configurations": {
        "production": {
          "buildTarget": "client-interface:build:production"
        },
        "development": {
          "buildTarget": "client-interface:build:development"
        },
        "mobile-dev": {
          "buildTarget": "client-interface:build:mobile-dev"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "client-interface:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/client-interface/jest.config.ts"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "client-interface:build",
        "port": 4200,
        "staticFilePath": "dist/apps/client-interface/browser",
        "spa": true
      }
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4400,
        "configDir": "apps/client-interface/.storybook",
        "browserTarget": "client-interface:build",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/client-interface",
        "configDir": "apps/client-interface/.storybook",
        "browserTarget": "client-interface:build",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "test-storybook -c apps/client-interface/.storybook --url=http://localhost:4400"
      }
    }
  }
}
