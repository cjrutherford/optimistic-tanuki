{
  "name": "admin-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/admin-api/src",
  "projectType": "application",
  "tags": ["type:app", "scope:admin", "platform:server", "visibility:internal"],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "options": {
        "webpackConfig": "apps/admin-api/webpack.config.js",
        "outputPath": "dist/apps/admin-api"
      },
      "configurations": {
        "development": {},
        "production": {}
      },
      "defaultConfiguration": "production"
    },
    "add-pg-dependency": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/add-pg-dep.js dist/apps/admin-api"
      },
      "dependsOn": ["build"]
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "admin-api:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "admin-api:build:development"
        },
        "production": {
          "buildTarget": "admin-api:build:production"
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/admin-api/jest.config.ts"
      }
    }
  }
}
