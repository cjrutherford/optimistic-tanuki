{
  "name": "gateway-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": [
    "gateway"
  ],
  "targets": {
    "up": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f e2e/docker-compose.gateway-e2e.yaml up -d --build"
      }
    },
    "down": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f e2e/docker-compose.gateway-e2e.yaml down -v"
      }
    },
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{e2eProjectRoot}"
      ],
      "options": {
        "jestConfig": "apps/gateway-e2e/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "e2e-docker": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run gateway-e2e:up",
          "echo 'Waiting for services to stabilize (30s)...'",
          "sleep 30",
          "nx run gateway-e2e:e2e",
          "nx run gateway-e2e:down"
        ],
        "parallel": false
      }
    }
  }
}