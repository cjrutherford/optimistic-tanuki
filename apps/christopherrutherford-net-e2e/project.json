{
  "name": "christopherrutherford-net-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/christopherrutherford-net-e2e/src",
  "implicitDependencies": [
    "christopherrutherford-net"
  ],
  "// targets": "to see all targets run: nx show project christopherrutherford-net-e2e --web",
  "targets": {
    "up": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f e2e/docker-compose.christopherrutherford-net-e2e.yaml up -d --build"
      }
    },
    "down": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f e2e/docker-compose.christopherrutherford-net-e2e.yaml down -v"
      }
    },
    "e2e": {
      "executor": "@nx/playwright:playwright",
      "options": {},
      "configurations": {
        "ci": {
          "env": {
            "BASE_URL": "http://localhost:8083"
          }
        }
      }
    },
    "e2e-docker": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run christopherrutherford-net-e2e:up",
          "echo 'Waiting for services to stabilize (45s)...'",
          "sleep 45",
          "nx run christopherrutherford-net-e2e:e2e",
          "nx run christopherrutherford-net-e2e:down"
        ],
        "parallel": false
      }
    }
  }
}